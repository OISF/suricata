[package]
name = "suricata-config"
version = "@PACKAGE_VERSION@"
edition = "2021"
license = "GPL-2.0-only"
description = "Suricata configuration tooling"
rust-version = "1.75.0"

[dependencies]
saphyr = { version = "0.0.6" }
saphyr-parser = { version = "0.0.6" }
serde_json = { version = "1.0.140", default-features = false, features = ["std", "preserve_order"] }
thiserror = "2.0.12"
